{
  "name": "vscode-jump-history",
  "displayName": "Jump History",
  "description": "自动记录 Ctrl+点击 和 Go to Definition 的跳转堆栈",
  "version": "0.0.1",
  "author": {
    "name": "conglinyizhi",
    "url": "https://github.com/conglinyizhi"
  },
  "repository": {
    "url": "https://github.com/conglinyizhi/vscode-jump-history"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "jumpHistory",
          "name": "Jump History"
        }
      ]
    },
    "commands": [
      {
        "command": "jumpHistory.clear",
        "title": "Clear Jump History",
        "icon": "$(clear-all)"
      },
      {
        "command": "jumpHistory.goToLocation",
        "title": "Go to Location"
      },
      {
        "command": "jumpHistory.expandAll",
        "title": "Expand All",
        "icon": "$(expand-all)"
      },
      {
        "command": "jumpHistory.collapseAll",
        "title": "Collapse All",
        "icon": "$(collapse-all)"
      },
      {
        "command": "jumpHistory.copy",
        "title": "Copy Jump Info",
        "icon": "$(copy)"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "jumpHistory.copy",
          "when": "view == jumpHistory",
          "group": "1_copy@1"
        }
      ],
      "view/title": [
        {
          "command": "jumpHistory.expandAll",
          "when": "view == jumpHistory",
          "group": "navigation@1"
        },
        {
          "command": "jumpHistory.collapseAll",
          "when": "view == jumpHistory",
          "group": "navigation@2"
        },
        {
          "command": "jumpHistory.clear",
          "when": "view == jumpHistory",
          "group": "navigation@9"
        }
      ]
    },
    "keybindings": [
      {
        "command": "jumpHistory.copy",
        "key": "ctrl+c",
        "mac": "cmd+c",
        "when": "view == jumpHistory && viewItem == jumpRecord"
      }
    ],
    "colors": [
      {
        "id": "jumpHistory.highlight1",
        "description": "Jump History highlight color 1",
        "defaults": {
          "dark": "#c87878",
          "light": "#a05050"
        }
      },
      {
        "id": "jumpHistory.highlight2",
        "description": "Jump History highlight color 2",
        "defaults": {
          "dark": "#78a078",
          "light": "#507050"
        }
      },
      {
        "id": "jumpHistory.highlight3",
        "description": "Jump History highlight color 3",
        "defaults": {
          "dark": "#7896b4",
          "light": "#507090"
        }
      },
      {
        "id": "jumpHistory.highlight4",
        "description": "Jump History highlight color 4",
        "defaults": {
          "dark": "#b4a064",
          "light": "#907040"
        }
      },
      {
        "id": "jumpHistory.highlight5",
        "description": "Jump History highlight color 5",
        "defaults": {
          "dark": "#a078a0",
          "light": "#805080"
        }
      },
      {
        "id": "jumpHistory.highlight6",
        "description": "Jump History highlight color 6",
        "defaults": {
          "dark": "#64a0aa",
          "light": "#408090"
        }
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "fmt": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\" \"./*.{json,md}\""
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.74.0",
    "prettier": "^3.8.1",
    "typescript": "^5.0.0"
  }
}
